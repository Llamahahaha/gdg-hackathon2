# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
# Video & Media
public/videos/
vision/visionplay-pipeline/input_videos/
vision/visionplay-pipeline/output_videos/
vision/visionplay-pipeline/extracted_frames/
vision/visionplay-pipeline/processed_frames/

# Explicitly ensure the pipeline code is tracked
!vision/visionplay-pipeline/src/
!vision/visionplay-pipeline/*.py

# AI Models (Very Large)
vision/models/*.pt
vision/models/*.onnx

# Local Data & Logs
public/data/match_telemetry.json
lint_output*.txt
.venv/
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Catch-all for large media
*.mp4
*.mov
*.avi
*.mkv
*.weights
*.h5
*.onnx

